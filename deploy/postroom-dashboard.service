[Unit]
Description=Postroom Dashboard Flask
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=postroom
Group=postroom
WorkingDirectory=/opt/postroom
EnvironmentFile=/etc/postroom/env
ExecStart=/opt/postroom/.venv/bin/python src/dashboard.py --port 5002 --db /var/lib/postroom/postroom.db
Restart=on-failure
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/var/lib/postroom

[Install]
WantedBy=multi-user.target
